<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ParkingApp.PaymentDialog"
        Title="Платёж" Width="340" Height="250"
        CanResize="False" WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" Spacing="6">
        <TextBlock Text="Дата (YYYY-MM-DD)"/>
        <TextBox Name="DateBox"/>
        <TextBlock Text="Время (HH:MM)"/>
        <TextBox Name="TimeBox"/>
        <TextBlock Text="Тип (Single / Subscription)"/>
        <TextBox Name="TypeBox"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="Save_Click"/>
            <Button Content="Отмена"    Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
