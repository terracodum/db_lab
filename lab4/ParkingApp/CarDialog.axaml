<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ParkingApp.CarDialog"
        Title="Автомобиль" Width="340" Height="230"
        CanResize="False" WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" Spacing="6">
        <TextBlock Text="Гос. номер"/>
        <TextBox Name="PlateBox"/>
        <TextBlock Text="Тип автомобиля"/>
        <TextBox Name="TypeBox"/>
        <TextBlock Text="№ клиента"/>
        <TextBox Name="ClientBox"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="Save_Click"/>
            <Button Content="Отмена"    Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
